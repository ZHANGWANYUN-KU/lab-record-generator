<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lab Record Generator</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- React & ReactDOM -->
    <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    
    <!-- Babel for JSX -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">

    <style>
        /* Custom Font Class */
        .font-serif {
            font-family: 'Crimson Text', 'Times New Roman', serif;
        }
        
        /* Print Styles */
        @media print {
            @page {
                size: 195mm 270mm; /* 16K Size */
                margin: 0;
            }
            body {
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
                background: white;
            }
            .no-print {
                display: none !important;
            }
            .print-visible {
                display: block !important;
                height: 100%;
                overflow: visible !important;
            }
            /* Reset Main Layout for Print */
            #root, .app-container {
                display: block;
                height: auto;
                overflow: visible;
            }
        }
    </style>
</head>
<body class="bg-gray-100 text-gray-800">
    <div id="root"></div>

    <script type="text/babel">
        const { useState } = React;

        // --- Icons (Inline SVGs to replace Lucide dependency) ---
        const IconPrinter = ({ className }) => (
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
        );
        const IconPlus = ({ className }) => (
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        );
        const IconTrash2 = ({ className }) => (
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
        );
        const IconFlaskConical = ({ className }) => (
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"></path><path d="M8.5 2h7"></path><path d="M7 16h10"></path></svg>
        );
        const IconRotateCcw = ({ className }) => (
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path d="M3 3v5h5"></path></svg>
        );
        const IconX = ({ className }) => (
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        );

        // --- Main Component ---
        const LabRecordGenerator = () => {
            // --- Initial Sections (English) ---
            const initialSections = [
                { 
                id: 'sec-objects', 
                title: '1. Materials & Objects', 
                type: 'mixed-list', 
                items: [
                    { id: 'item-1', type: 'animal', animalType: 'Mouse', age: 'E14', group: 'Con', side: 'Right', note: '' },
                    { id: 'item-2', type: 'animal', animalType: 'Pup', age: 'P13', group: 'Exp 1', side: 'Left', note: '' },
                    { id: 'item-3', type: 'animal', animalType: 'Mouse', age: 'P15', group: 'Exp 2', side: 'Right', note: '' },
                    { id: 'item-4', type: 'animal', animalType: 'Pup', age: 'P14', group: 'Con', side: 'Right', note: '' }
                ]
                },
                { 
                id: 'sec-plasmid', 
                title: '2. Plasmid Information', 
                type: 'text',
                content: 'Name: pEGFP-C1-GeneX\nAntibiotic: Kanamycin\nSize: ~5.9 kb\nFeatures: \n  - Promoter: CMV IE\n  - Tag: EGFP (N-term)\n  - Cloning sites: EcoRI / BamHI'
                },
                { 
                id: 'sec-protocol', 
                title: '3. Protocol', 
                type: 'text',
                content: '1. [Transformation] Thaw 50µL DH5α competent cells on ice.\n2. Add 2µL ligation product, mix gently, incubate on ice for 30 min.\n3. [Heat Shock] 42℃ water bath for 90 sec, immediately transfer to ice for 2 min.\n4. Add 500µL SOC/LB medium (no antibiotics), recover at 37℃, 200rpm for 1 hour.\n5. [Plating] Spread 100µL culture onto LB agar plates containing Kanamycin.\n6. Incubate at 37℃ overnight (12-16h).' 
                },
                { 
                    id: 'sec-results', 
                    title: '4. Expected Results & Notes', 
                    type: 'text',
                    content: 'Colonies are expected on the experimental plate. The negative control (no plasmid) should show no growth. Pick single colonies for colony PCR verification.' 
                }
            ];

            const [meta, setMeta] = useState({
                title: 'Plasmid Construction and Transformation Record',
                experimentId: 'EXP-2023-10-01',
                date: new Date().toISOString().split('T')[0],
                time: '14:30',
                researcher: 'Zhang Wanyun',
                labName: 'Hidenobu Mizuno lab',
                supervisor: 'Prof. Mizuno'
            });

            const [sections, setSections] = useState(initialSections);
            
            // Options
            const researcherOptions = ["Zhang Wanyun", "John Doe", "Jane Smith", "Lab Assistant", "Other"];
            const animalTypes = ["Mouse", "Pup"];
            const animalAges = ["E14", "E15", "P13", "P14", "P15"];
            const groupOptions = ["Con", "Exp 1", "Exp 2", "WT", "KO", "Other"];
            const sideOptions = ["Right", "Left"];

            // --- Handlers ---
            const handleMetaChange = (e) => {
                const { name, value } = e.target;
                setMeta(prev => ({ ...prev, [name]: value }));
            };

            const handleSectionTitleChange = (id, newTitle) => {
                setSections(prev => prev.map(sec => sec.id === id ? { ...sec, title: newTitle } : sec));
            };

            const handleSectionContentChange = (id, newContent) => {
                setSections(prev => prev.map(sec => sec.id === id ? { ...sec, content: newContent } : sec));
            };

            const addListItem = (sectionId) => {
                setSections(prev => prev.map(sec => {
                    if (sec.id !== sectionId) return sec;
                    const newItem = { 
                        id: `item-${Date.now()}`, 
                        type: 'animal', 
                        animalType: 'Mouse', 
                        age: 'E14', 
                        group: 'Con', 
                        side: 'Right', 
                        note: '' 
                    };
                    return { ...sec, items: [...(sec.items || []), newItem] };
                }));
            };

            const updateListItem = (sectionId, itemId, field, value) => {
                setSections(prev => prev.map(sec => {
                    if (sec.id !== sectionId) return sec;
                    return {
                        ...sec,
                        items: (sec.items || []).map(item => item.id === itemId ? { ...item, [field]: value } : item)
                    };
                }));
            };

            const removeListItem = (sectionId, itemId) => {
                setSections(prev => prev.map(sec => {
                    if (sec.id !== sectionId) return sec;
                    return { ...sec, items: (sec.items || []).filter(item => item.id !== itemId) };
                }));
            };

            const addSection = () => {
                const newId = `sec-${Date.now()}`;
                const num = sections.length + 1;
                setSections([...sections, { id: newId, title: `${num}. New Section`, content: '', type: 'text' }]);
            };

            const removeSection = (id) => {
                setSections(prev => prev.filter(sec => sec.id !== id));
            };

            const handlePrint = () => {
                const originalTitle = document.title;
                const printTitle = `${meta.experimentId || 'Experiment'}_${meta.date}`;
                document.title = printTitle;
                window.print();
                setTimeout(() => {
                document.title = originalTitle;
                }, 500);
            };

            const handleReset = () => {
                if(window.confirm('Reset to default template?')) {
                    setSections(initialSections);
                    setMeta({
                        title: 'Plasmid Construction and Transformation Record',
                        experimentId: 'EXP-2023-10-01',
                        date: new Date().toISOString().split('T')[0],
                        time: '14:30',
                        researcher: 'Zhang Wanyun',
                        labName: 'Hidenobu Mizuno lab',
                        supervisor: 'Prof. Mizuno'
                    });
                }
            };

            return (
                <div className="app-container min-h-screen bg-gray-100 font-sans flex flex-col md:flex-row print:bg-white print:block">
                
                {/* --- Left Panel: Editor --- */}
                <div className="no-print w-full md:w-1/3 lg:w-96 bg-white border-r border-gray-200 flex flex-col h-screen sticky top-0 shadow-lg z-10">
                    <div className="p-3 border-b border-gray-200 bg-gray-50 flex items-center justify-between">
                    <div className="flex items-center gap-2 font-bold text-gray-700">
                        <IconFlaskConical className="w-5 h-5 text-gray-800" />
                        <span>Lab Editor</span>
                    </div>
                    <button onClick={handleReset} className="text-gray-400 hover:text-red-500 transition-colors" title="Reset">
                        <IconRotateCcw className="w-4 h-4" />
                    </button>
                    </div>

                    <div className="flex-1 overflow-y-auto p-4 space-y-5">
                    {/* Header Info */}
                    <div className="space-y-2">
                        <h3 className="text-xs font-bold text-gray-400 uppercase tracking-wider">Header Info</h3>
                        <div className="grid grid-cols-1 gap-2">
                        <input name="title" value={meta.title} onChange={handleMetaChange} placeholder="Title" className="w-full p-2 text-sm border rounded focus:ring-2 focus:ring-gray-500 outline-none font-medium" />
                        <div className="grid grid-cols-1 gap-2">
                            <input name="labName" value={meta.labName} onChange={handleMetaChange} placeholder="Lab Name" className="w-full p-2 text-sm border rounded focus:ring-2 focus:ring-gray-500 outline-none" />
                            <input name="experimentId" value={meta.experimentId} onChange={handleMetaChange} placeholder="Exp ID (Internal)" className="w-full p-2 text-sm border rounded focus:ring-2 focus:ring-gray-500 outline-none bg-gray-50 text-gray-500" />
                        </div>
                        <div className="grid grid-cols-2 gap-2">
                            <input type="date" name="date" value={meta.date} onChange={handleMetaChange} className="w-full p-2 text-sm border rounded focus:ring-2 focus:ring-gray-500 outline-none" />
                            <input type="time" name="time" value={meta.time} onChange={handleMetaChange} className="w-full p-2 text-sm border rounded focus:ring-2 focus:ring-gray-500 outline-none" />
                        </div>
                        <div className="grid grid-cols-1 gap-2">
                            <select name="researcher" value={meta.researcher} onChange={handleMetaChange} className="w-full p-2 text-sm border rounded focus:ring-2 focus:ring-gray-500 outline-none bg-white">
                                <option value="" disabled>Select Researcher</option>
                                {researcherOptions.map(opt => <option key={opt} value={opt}>{opt}</option>)}
                            </select>
                            <input name="supervisor" value={meta.supervisor} onChange={handleMetaChange} placeholder="Supervisor" className="w-full p-2 text-sm border rounded focus:ring-2 focus:ring-gray-500 outline-none" />
                        </div>
                        </div>
                    </div>

                    <hr className="border-gray-200" />

                    {/* Sections Editor */}
                    <div className="space-y-4">
                        <h3 className="text-xs font-bold text-gray-400 uppercase tracking-wider">Content Blocks</h3>
                        
                        {sections.map((section) => (
                        <div key={section.id} className="bg-white border border-gray-200 rounded-lg p-3 shadow-sm relative">
                            
                            {/* Section Title Header */}
                            <div className="flex justify-between items-center mb-2 pb-2 border-b border-gray-100">
                                <input 
                                value={section.title} 
                                onChange={(e) => handleSectionTitleChange(section.id, e.target.value)}
                                className="font-bold text-sm text-gray-800 w-full outline-none bg-transparent"
                                placeholder="Section Title"
                                />
                                <button onClick={() => removeSection(section.id)} className="text-gray-300 hover:text-red-500 p-1">
                                <IconTrash2 className="w-4 h-4" />
                                </button>
                            </div>

                            {/* Section Content Logic */}
                            {section.type === 'mixed-list' ? (
                            <div className="space-y-2">
                                <div className="space-y-2 max-h-[400px] overflow-y-auto">
                                    {section.items?.map((item, idx) => (
                                        <div key={item.id} className="flex gap-2 items-start bg-gray-50 p-2 rounded text-xs border border-gray-100">
                                            <span className="text-gray-400 mt-1 select-none font-mono font-bold w-4">{idx + 1}.</span>
                                            <div className="flex-1 space-y-2">
                                                <div className="flex flex-col gap-2">
                                                    {/* Row 1: Type, Age, Group, Side */}
                                                    <div className="flex gap-1">
                                                        <select 
                                                            value={item.animalType} 
                                                            onChange={(e) => updateListItem(section.id, item.id, 'animalType', e.target.value)}
                                                            className="border rounded p-1 bg-white w-1/4 text-gray-700"
                                                            title="Type"
                                                        >
                                                            {animalTypes.map(t => <option key={t} value={t}>{t}</option>)}
                                                        </select>
                                                        <select 
                                                            value={item.age} 
                                                            onChange={(e) => updateListItem(section.id, item.id, 'age', e.target.value)}
                                                            className="border rounded p-1 bg-white w-1/4 text-gray-700"
                                                            title="Age"
                                                        >
                                                            {animalAges.map(a => <option key={a} value={a}>{a}</option>)}
                                                        </select>
                                                        <select 
                                                            value={item.group} 
                                                            onChange={(e) => updateListItem(section.id, item.id, 'group', e.target.value)}
                                                            className="border rounded p-1 bg-white w-1/4 text-gray-700 font-medium"
                                                            title="Group"
                                                        >
                                                            {groupOptions.map(g => <option key={g} value={g}>{g}</option>)}
                                                        </select>
                                                        {/* Side Dropdown */}
                                                        <select 
                                                            value={item.side} 
                                                            onChange={(e) => updateListItem(section.id, item.id, 'side', e.target.value)}
                                                            className="border rounded p-1 bg-white w-1/4 text-gray-700 font-medium"
                                                            title="Side"
                                                        >
                                                            {sideOptions.map(s => <option key={s} value={s}>{s}</option>)}
                                                        </select>
                                                    </div>
                                                    {/* Row 2: Note */}
                                                    <input 
                                                        value={item.note}
                                                        onChange={(e) => updateListItem(section.id, item.id, 'note', e.target.value)}
                                                        placeholder="Details (e.g. Wild type, C57BL/6)..."
                                                        className="border rounded p-1 w-full bg-white text-gray-600"
                                                    />
                                                </div>
                                            </div>
                                            <button onClick={() => removeListItem(section.id, item.id)} className="text-gray-300 hover:text-red-500 mt-1">
                                                <IconX className="w-3 h-3" />
                                            </button>
                                        </div>
                                    ))}
                                </div>
                                <div className="pt-1">
                                    <button 
                                        onClick={() => addListItem(section.id)}
                                        className="w-full py-1.5 text-xs border border-blue-200 text-blue-600 rounded hover:bg-blue-50 flex justify-center items-center gap-1 transition-colors"
                                    >
                                        <IconPlus className="w-3 h-3" /> Add Object
                                    </button>
                                </div>
                            </div>
                            ) : (
                            <textarea 
                                value={section.content}
                                onChange={(e) => handleSectionContentChange(section.id, e.target.value)}
                                className="w-full text-xs text-gray-600 p-2 bg-gray-50 rounded border-transparent focus:bg-white focus:ring-1 focus:ring-gray-200 outline-none resize-y min-h-[100px] font-mono leading-relaxed"
                                placeholder="Content..."
                            />
                            )}
                        </div>
                        ))}
                        
                        <button 
                        onClick={addSection}
                        className="w-full py-2 border-2 border-dashed border-gray-300 rounded-lg text-gray-500 hover:border-gray-500 hover:text-gray-600 flex items-center justify-center gap-2 transition-colors font-medium text-sm"
                        >
                        <IconPlus className="w-4 h-4" /> Add Text Section
                        </button>
                    </div>
                    </div>

                    {/* Footer */}
                    <div className="p-4 border-t border-gray-200 bg-white">
                    <button onClick={handlePrint} className="w-full bg-gray-800 hover:bg-gray-900 text-white py-3 rounded-lg flex items-center justify-center gap-2 font-semibold shadow">
                        <IconPrinter className="w-5 h-5" /> Export PDF
                    </button>
                    </div>
                </div>

                {/* --- Right Panel: Compact 16K Preview --- */}
                <div className="print-visible flex-1 bg-gray-200 p-8 overflow-y-auto print:p-0 print:bg-white print:overflow-visible">
                    
                    <div 
                        className="mx-auto bg-white shadow-2xl print:shadow-none print:mx-0 relative flex flex-col"
                        style={{ 
                            width: '195mm', 
                            minHeight: '270mm',
                            padding: '15mm 15mm', 
                        }}
                    >
                        {/* --- Compact Header --- */}
                        <header className="mb-4 border-b-2 border-black pb-2 font-serif">
                            {/* Removed the Main Title as requested */}
                            
                            <div className="flex justify-between items-end text-[9pt] text-black">
                                <div className="italic font-bold text-[10pt]">{meta.labName}</div>
                                
                                {/* Header Row: Date | Res | Sup - Aligned on the same line */}
                                <div className="flex gap-6">
                                    <span><strong>Date:</strong> {meta.date} {meta.time}</span>
                                    <span><strong>Res:</strong> {meta.researcher}</span>
                                    <span><strong>Sup:</strong> {meta.supervisor}</span>
                                </div>
                            </div>
                        </header>

                        {/* --- Content Area --- */}
                        <div className="flex-1 space-y-4 font-serif">
                            {sections.map((section) => (
                                <section key={section.id} className="break-inside-avoid">
                                    {/* Compact Section Title */}
                                    <h2 className="text-[9pt] font-bold text-black mb-1 uppercase border-b border-gray-400 inline-block pr-2">
                                        {section.title}
                                    </h2>
                                    
                                    {/* Section Content */}
                                    <div className="text-[8pt] leading-snug text-justify text-black mt-1 pl-1">
                                        {section.type === 'mixed-list' ? (
                                            /* Grid Layout: 2 Columns (Left 1, Right 2, Left 3...) */
                                            <div className="grid grid-cols-2 gap-x-6 gap-y-1">
                                                {section.items?.map((item, idx) => (
                                                    <div key={item.id} className="flex">
                                                        <span className="font-bold mr-1">{idx + 1}.</span>
                                                        <span className="whitespace-nowrap overflow-hidden text-ellipsis">
                                                            {/* Format: Mouse(E14), Group (Con)— Note, Side */}
                                                            <span className="font-semibold">{item.animalType}</span>
                                                            <span>({item.age}), </span>
                                                            <span>Group ({item.group})</span>
                                                            <span> — </span>
                                                            {item.note && <span>{item.note}, </span>}
                                                            <span className="italic">{item.side}</span>
                                                        </span>
                                                    </div>
                                                ))}
                                            </div>
                                        ) : (
                                            <div className="whitespace-pre-wrap">{section.content}</div>
                                        )}
                                    </div>
                                </section>
                            ))}
                        </div>

                        {/* --- Footer --- */}
                        <footer className="mt-auto pt-4 border-t border-black flex justify-between items-end text-[7pt] font-serif text-black">
                            <div>Lab Record / {meta.date}</div>
                            <div>Page 1</div>
                        </footer>
                    </div>
                </div>
                </div>
            );
        };

        const rootElement = document.getElementById('root');
        if (rootElement) {
            const root = ReactDOM.createRoot(rootElement);
            root.render(<LabRecordGenerator />);
        } else {
            console.error('Root element not found');
        }
    </script>
</body>
</html>